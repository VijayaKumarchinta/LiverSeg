```gitignore
# ─────────────────────────────────────────────
# NODE / FRONTEND
# ─────────────────────────────────────────────
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend envs
frontend/.env
frontend/.env.local

# ─────────────────────────────────────────────
# PYTHON / DJANGO
# ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.env.production

venv/
.venv/
env/

# Django runtime
db.sqlite3
media/
static/
staticfiles/

# Logs
logs/
*.log
backend/logs/

# Cache
.pytest_cache/
.mypy_cache/

# ─────────────────────────────────────────────
# ENV / SECRETS
# ─────────────────────────────────────────────
.env
.env.*
backend/.env
backend/.env.*
!.env.example

# ─────────────────────────────────────────────
# DATABASES / DUMPS
# ─────────────────────────────────────────────
*.db
*.sqlite3
*.sql
*.dump
postgres_data/
db_data/
redis_data/

# ─────────────────────────────────────────────
# MEDICAL / PHI FILES
# ─────────────────────────────────────────────
*.nii
*.nii.gz
*.dcm

uploads/
patient_uploads/
ct_scans/
liver_masks/
dicom/

# ─────────────────────────────────────────────
# ML / AI MODELS
# ─────────────────────────────────────────────
*.pth
*.pt
*.ckpt
*.onnx
models/

# ─────────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────────
# ZIPS / ARTIFACTS / BACKUPS
# ─────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.bak

backup/
backups/
artifacts/
releases/

# ─────────────────────────────────────────────
# IDE / OS
# ─────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
```
